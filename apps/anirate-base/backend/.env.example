# ============================================================
# BACKEND - copy this file to backend/.env and fill in values
# ============================================================

# Database
# The current local demo uses seeded in-memory data, so this value is preserved
# for future database wiring and deployment work rather than required for boot.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/anime_platform?schema=public"

# JWT - generate with: openssl rand -hex 64
JWT_SECRET="CHANGE_ME_generate_a_long_random_secret"

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Email - used for password reset when you wire a real SMTP provider
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM="AniRate <noreply@example.com>"
